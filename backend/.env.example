# Origin allowed to call this API in production (your deployed frontend URL).
# Accepts a comma-separated list. http://localhost:3000 is always allowed
# for local development.
FRONTEND_ORIGIN=http://localhost:3000

# Financial Modeling Prep API key, used for fundamentals (key statistics,
# financial statements, and the DCF/LBO/comps model inputs).
#
# Why this exists: Yahoo's fundamentals endpoint is crumb-gated and returns
# 429 to datacenter IPs, so it works on a laptop but not from a deployed
# host. Price, charts, the market tape, movers, and search still come from
# Yahoo and need no key.
#
# Without a key the app still runs: quotes, charts, the tape, movers,
# search, and the company name all work, but fundamentals degrade (locally
# they fall back to yfinance; on a deployed host they will be blank).
# Get a free key at https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=
